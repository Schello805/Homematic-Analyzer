{
  "name": "homematic-analyzer",
  "version": "0.1.120",
  "private": true,
  "homepage": "https://github.com/Schello805/Homematic-Analyzer",
  "repository": {
    "type": "git",
    "url": "https://github.com/Schello805/Homematic-Analyzer.git"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "start": "tsx server/index.ts",
    "check": "tsc --noEmit",
    "test": "tsx --test server/*.test.ts",
    "test:install": "bash scripts/test-installation.sh",
    "release:push": "node scripts/release/push-with-version.mjs"
  },
  "dependencies": {
    "@types/nodemailer": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.8.0",
    "nodemailer": "^8.0.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.30"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
